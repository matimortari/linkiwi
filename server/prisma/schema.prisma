generator client {
  provider = "prisma-client"
  output   = "../../.data/prisma"
}

datasource db {
  provider = "postgresql"
}

enum BackgroundType {
  FLAT
  GRADIENT
}

enum SupportBanner {
  NONE
  LGBTQ_RIGHTS
  ANTI_RACISM
  MENTAL_HEALTH
  CLIMATE_ACTION
}

enum ScheduleAction {
  HIDE
  DELETE
}

enum ProfileItemType {
  LINK
  WIDGET
  ICON
  DIVIDER
  PHOTO_GRID
}

enum WidgetType {
  GITHUB
  YOUTUBE
  SPOTIFY
}

model Account {
  id                String   @id @default(cuid())
  userId            String
  provider          String
  providerAccountId String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([provider, providerAccountId])
}

model User {
  id          String           @id @default(cuid())
  email       String           @unique
  name        String
  image       String?
  slug        String           @unique
  description String?
  location    String?
  preferences UserPreferences? @relation("UserPreferences")
  banner      UserBanner?      @relation("UserBanner")
  items       ProfileItem[]
  assets      UserAsset[]
  views       PageView[]
  comments    Comment[]
  accounts    Account[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model UserPreferences {
  userId                    String         @id
  backgroundType            BackgroundType @default(FLAT)
  backgroundColor           String         @default("#f5f7fa")
  backgroundGradientStart   String         @default("#000000")
  backgroundGradientEnd     String         @default("#000000")
  profilePictureRadius      String         @default("0.5rem")
  profilePictureBorderColor String         @default("#d1dae3")
  profilePictureBorderWidth String         @default("2px")
  slugTextColor             String         @default("#1e293b")
  slugTextWeight            String         @default("400")
  slugTextSize              String         @default("1rem")
  slugFontFamily            String         @default("'Roboto', sans-serif")
  headerTextColor           String         @default("#334155")
  headerTextWeight          String         @default("400")
  headerTextSize            String         @default("1.1rem")
  headerFontFamily          String         @default("'Roboto', sans-serif")
  linkBackgroundColor       String         @default("#e2e8f0")
  linkTextColor             String         @default("#475569")
  linkTextWeight            String         @default("400")
  linkTextSize              String         @default("0.9rem")
  linkFontFamily            String         @default("'Roboto', sans-serif")
  isLinkShadow              Boolean        @default(false)
  linkShadowColor           String         @default("#94a3b8")
  linkShadowWeight          String         @default("medium")
  linkHoverBackgroundColor  String         @default("#cbd5e1")
  linkBorderRadius          String         @default("0.5rem")
  linkPadding               String         @default("0.5rem")
  showLinkCopyButton        Boolean        @default(true)
  iconBackgroundColor       String         @default("#e2e8f0")
  isIconShadow              Boolean        @default(false)
  iconShadowColor           String         @default("#94a3b8")
  iconShadowWeight          String         @default("medium")
  iconLogoColor             String         @default("#475569")
  iconHoverBackgroundColor  String         @default("#cbd5e1")
  dividerColor              String         @default("#e2e8f0")
  dividerThickness          String         @default("1px")
  dividerStyle              String         @default("solid")
  supportBanner             SupportBanner  @default(NONE)
  enableGuestbook           Boolean        @default(false)
  user                      User           @relation("UserPreferences", fields: [userId], references: [id], onDelete: Cascade)
}

model UserBanner {
  id        String     @id @default(cuid())
  userId    String     @unique
  assetId   String?    @unique
  url       String
  user      User       @relation("UserBanner", fields: [userId], references: [id], onDelete: Cascade)
  asset     UserAsset? @relation(fields: [assetId], references: [id], onDelete: SetNull)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model UserAsset {
  id        String          @id @default(cuid())
  userId    String
  url       String
  key       String
  mimeType  String
  size      Int
  label     String?
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  banner    UserBanner?
  photos    PhotoGridItem[]
  links     ProfileItemLink[]
  createdAt DateTime        @default(now())

  @@index([userId])
}

model ProfileItem {
  id             String                @id @default(cuid())
  userId         String
  type           ProfileItemType
  order          Int                   @default(0)
  isPinned       Boolean               @default(false)
  isVisible      Boolean               @default(true)
  scheduledStart DateTime?
  scheduledEnd   DateTime?
  scheduleAction ScheduleAction?
  user           User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  link           ProfileItemLink?
  widget         ProfileItemWidget?
  icon           ProfileItemIcon?
  photoGrid      ProfileItemPhotoGrid?
  clicks         ItemClick[]
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  @@index([userId, order])
  @@index([userId, isPinned])
}

model ProfileItemLink {
  itemId   String      @id
  url      String
  label    String
  assetId  String?
  imageUrl String?
  item     ProfileItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  asset    UserAsset?  @relation(fields: [assetId], references: [id], onDelete: SetNull)
}

model ProfileItemWidget {
  itemId String      @id
  type   WidgetType
  handle String
  item   ProfileItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
}

model ProfileItemIcon {
  itemId   String      @id
  url      String
  platform String?
  logo     String?
  item     ProfileItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
}

model ProfileItemPhotoGrid {
  itemId String          @id
  item   ProfileItem     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  photos PhotoGridItem[]
}

model PhotoGridItem {
  id      String               @id @default(cuid())
  gridId  String
  assetId String?
  url     String
  order   Int                  @default(0)
  alt     String?
  grid    ProfileItemPhotoGrid @relation(fields: [gridId], references: [itemId], onDelete: Cascade)
  asset   UserAsset?           @relation(fields: [assetId], references: [id], onDelete: SetNull)

  @@index([gridId, order])
}

model Comment {
  id        String   @id @default(cuid())
  userId    String
  name      String
  email     String?
  message   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model PageView {
  id        String   @id @default(cuid())
  userId    String
  referrer  String?
  source    String?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

model ItemClick {
  id        String      @id @default(cuid())
  itemId    String
  createdAt DateTime    @default(now())
  item      ProfileItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId, createdAt])
}
